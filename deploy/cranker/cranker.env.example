# Cranker runtime configuration. Copy to `cranker.env` and fill in.
# All variables are validated at boot by the Zod schema in
# packages/cranker/src/config.ts — boot fails fast if anything is wrong.

# ─── Required ──────────────────────────────────────────────────────────

# Paid Solana mainnet RPC. PUBLIC mainnet-beta is REJECTED at boot
# because it disables getProgramAccounts which the scanner requires.
# Helius / QuickNode / Triton are known-good.
SOLANA_RPC_URL=https://your-paid-rpc.example.com
SOLANA_WS_URL=wss://your-paid-rpc.example.com

# FOGO RPC.
FOGO_RPC_URL=https://mainnet.fogo.io

# Cranker keypair file (Solana JSON-array secret-key format).
# Mounted read-only from the host — see docker-compose.yml volume.
# IMPORTANT: this key MUST NOT equal PairConfig.authority. The cranker
# is grief-only; co-locating with authority gives a stolen host fee +
# redemption-cancel powers. Boot aborts if the invariant is violated.
KEYPAIR_PATH=/secrets/cranker-keypair.json

# ─── Wormholescan flow enumeration ─────────────────────────────────────

# Wormholescan API base. Default is the public hosted endpoint and is
# fine for production; override only if you run a private instance.
WORMHOLESCAN_URL=https://api.wormholescan.io

# Pagination knobs for the VAA-listing call. Higher pageSize = fewer
# round-trips, higher maxPages = deeper backfill on cold start. Defaults
# tuned for normal steady-state operation; raise maxPages temporarily
# after a long outage to backfill the queue.
WORMHOLESCAN_PAGE_SIZE=50
WORMHOLESCAN_MAX_PAGES=2

# FOGO's Wormhole chain ID. Defaults to the SDK constant (51 = FOGO
# mainnet). Override only if you're pointing at a different source chain.
# FOGO_WORMHOLE_CHAIN_ID=51

# 32-byte hex (no 0x prefix) emitter addresses of the FOGO-side NTT
# managers. Both default to the `["emitter"]` PDA derived from the
# SDK's NTT_USDC_PROGRAM_ID / NTT_ONYC_PROGRAM_ID. Override only when
# pointing at a redeployed manager (testnet, fork, etc).
# FOGO_USDC_EMITTER_HEX=
# FOGO_ONYC_EMITTER_HEX=

# ─── Metrics + healthz ─────────────────────────────────────────────────

# Network port for /metrics and /healthz. Bound 0.0.0.0 inside the
# container; compose binds 127.0.0.1:9090 on the host so Tailscale-only
# operators see it but the public internet does not.
METRICS_PORT=9090

# ─── Scan loop tuning ──────────────────────────────────────────────────

# Base interval between scan iterations (success path).
SCAN_INTERVAL_MS=30000

# Cap on exponential backoff after consecutive scan errors. Backoff is
# intervalMs * 2^errors, clamped at this cap. 5 minutes is a sane
# default for a flapping RPC; raise for a more deferential daemon.
SCAN_MAX_BACKOFF_MS=300000

# How long the daemon waits for an in-flight scan to drain on SIGTERM
# before abandoning it. Must be < Docker's stop_grace_period (30s) so
# we don't lose to SIGKILL mid-cleanup.
SHUTDOWN_DEADLINE_MS=8000

# How often to poll the cranker's SOL balance for the
# `cranker_keypair_sol_balance` gauge (powers the LowSol alert).
BALANCE_POLL_INTERVAL_MS=60000

# Per-RPC-call timeout. Caps any single getProgramAccounts /
# getMultipleAccounts so a stuck RPC can't pin a worker forever.
RPC_TIMEOUT_MS=15000

# Per-Wormholescan-call timeout.
WORMHOLESCAN_TIMEOUT_MS=10000

# Heartbeat-staleness threshold for the self-kill watchdog. If the scan
# loop fails to stamp the heartbeat for this long, the daemon
# process.exit(1)s so Docker's restart policy lifts it. Must be >>
# SCAN_INTERVAL_MS + worst-case scan duration; 2 min is comfortable.
HEARTBEAT_STALE_MS=120000

# ─── Concurrency ───────────────────────────────────────────────────────

# Max simultaneous advance dispatches. Each advance is one CPI tx;
# higher numbers reduce per-flow latency but raise SOL burn rate during
# bursts. Stay << RPC provider's per-second cap.
MAX_CONCURRENT_ADVANCES=4

# ─── Observability ─────────────────────────────────────────────────────

# debug | info | warn | error. JSON-per-line on stderr.
LOG_LEVEL=info
