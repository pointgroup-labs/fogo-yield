# Generated by Cargo
# will have compiled files and executables
debug/
target/
.run/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# IDEs and editors
/.idea

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

node_modules/
dist/
.anchor/

test-ledger/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

tsconfig.tsbuildinfo


# Mac OSX temporary files
.DS_Store
**/.DS_Store

.eslintcache
#bun.lockb
.env

.keys
.claude
CLAUDE.md

tmp

/keypair.json

# Next.js build output
**/.next/
# Static-export output (`output: 'export'` in next.config.ts)
**/out/

# Secrets — anywhere in the tree. Covers operator keypairs, the
# docker-compose `./secrets/` mount, and any .env file under deploy/.
# Never commit these: a leaked keypair is the relayer authority, a leaked
# RPC api-key is a billable resource, and cranker.env usually has both.
/deploy/**/*.env
/deploy/**/secrets/
**/*keypair*.json
**/*.key
.keypair.json
# Solana CLI default wallet name — operators copy it into the tree by accident.
/id.json
/deploy/**/id.json

# Cranker runtime state — per-instance Wormholescan watermarks. Generated
# at the path set by `CHECKPOINT_PATH` (defaults to ./cranker-checkpoint.json).
# Committing this would cause a fresh deploy to start with stale watermarks
# and silently skip historical VAAs.
cranker-checkpoint.json
*-checkpoint.json

docs/superpowers/


/design
