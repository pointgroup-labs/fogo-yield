# --------------------------------------------------------------------------
# REQUIRED. Domain registered with the Fogo paymaster.
# --------------------------------------------------------------------------
# The Fogo paymaster will reject any `domain` that isn't pre-registered
# with their service — you'll see a 400 from
#   /api/sponsor_pubkey?domain=...
# at session-establish time. This string is just a lookup key; it doesn't
# have to match the URL the page is served from, so the same value works
# in local dev as in production.
#
# To get a domain registered, reach out to the Fogo team.
NEXT_PUBLIC_APP_DOMAIN=https://app.fogo-onre.example

# --------------------------------------------------------------------------
# Optional overrides.
# --------------------------------------------------------------------------
# `mainnet` (default) or `testnet`. The RPC URL below auto-follows this.
NEXT_PUBLIC_FOGO_NETWORK=mainnet

# Override the FOGO RPC. Defaults to https://mainnet.fogo.io or
# https://testnet.fogo.io based on NEXT_PUBLIC_FOGO_NETWORK.
# NEXT_PUBLIC_FOGO_RPC_URL=https://mainnet.fogo.io

# Solana RPC for cross-chain operations. Defaults to mainnet-beta.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
