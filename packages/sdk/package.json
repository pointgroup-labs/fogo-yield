{
  "name": "@fogo-onre/sdk",
  "type": "module",
  "version": "1.0.0",
  "description": "Fogo-OnRe SDK — TypeScript client",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prebuild": "mkdir -p src/idl && cp ../../target/idl/fogo_onre_relayer.json src/idl/fogo_onre_relayer.json",
    "build": "tsc",
    "clean": "rm -rf dist src/idl/fogo_onre_relayer.json"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.0",
    "@noble/hashes": "^2.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
