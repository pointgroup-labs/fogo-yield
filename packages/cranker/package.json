{
  "name": "@fogo-onre/cranker",
  "version": "0.1.0",
  "private": true,
  "description": "Fogo-OnRe permissionless cranker daemon",
  "bin": {
    "cranker": "./dist/bin.js"
  },
  "exports": {
    "./vaa": {
      "types": "./dist/vaa.d.ts",
      "default": "./dist/vaa.js"
    },
    "./wormholescan": {
      "types": "./dist/wormholescan.d.ts",
      "default": "./dist/wormholescan.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.2",
    "@fogo-onre/sdk": "workspace:*",
    "@noble/hashes": "^1.8.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "@wormhole-foundation/sdk-definitions": "^4.18.0",
    "@wormhole-foundation/sdk-definitions-ntt": "^4.0.17",
    "@wormhole-foundation/sdk-solana-ntt": "^4.0.17",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
